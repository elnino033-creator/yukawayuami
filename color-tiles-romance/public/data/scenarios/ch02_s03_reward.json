  {
    "text": {
      "name": "みお",
      "body": "……ねえ。帰るとき、手、繋いでもいい？"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "（……みおから、言ってくるのは初めてだ）"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "……ああ"
    }
  },
  {
    "text": {
      "name": "",
      "body": "俺が手を出すと、みおはゆっくりと両手でそれを包んだ。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "まるで大切なものを持つように、静かに。"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "……冷たくてごめん。手、いつも冷えてるから"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "気にしない"
    }
  },
  {
    "text": {
      "name": "",
      "body": "みおの指先は確かに冷たかった。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "でも、包まれた手の中からじんわりと熱が移っていく。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "どちらかのあたたかさか、もしかしたら両方のか。"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "……あのさ。来てくれて、よかった"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "ここに。私のところに"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "俺も、よかったと思ってる"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "……うん"
    }
  },
  {
    "text": {
      "name": "",
      "body": "みおはそれだけ言って、小さく頷いた。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "繋いだ手を、ほんの少し強く握り直しながら。"
    }
  },
