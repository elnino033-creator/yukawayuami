  {
    "text": {
      "name": "ゆかり",
      "body": "最後の問いです。"
    }
  },
  {
    "text": {
      "name": "ゆかり",
      "body": "あなたは3年前、何をしましたか？"
    }
  },
  {
    "text": {
      "name": "",
      "body": "言葉が、口の奥でつかえた。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "それを口にしてしまえば、もう、知らなかったことには、できない。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "……キャンバスに、黒い絵の具を……"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "両手で、つかんで、ぶちまけた。何度も、何度も。"
    }
  },
  {
    "text": {
      "name": "ゆかり",
      "body": "その前に。"
    }
  },
  {
    "text": {
      "name": "ゆかり",
      "body": "キャンバスには何が描かれていましたか？"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "……誰かの、肖像が。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "とても大切な……"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "（顔が、見えそうで、見えない。微笑んでいた。でも、その微笑みの主が、誰なのか——）"
    }
  },
  {
    "chara": {
      "id": "yukari",
      "expr": "sad",
      "pos": "center"
    }
  },
  {
    "text": {
      "name": "ゆかり",
      "body": "……もうすぐです。"
    }
  },
  {
    "text": {
      "name": "ゆかり",
      "body": "最後のパズルの先に、すべての答えがある。"
    }
  },
  {
    "text": {
      "name": "ゆかり",
      "body": "それでも、進みますね？"
    }
  }
]
