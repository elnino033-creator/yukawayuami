      "expr": "angry",
      "pos": "center"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "あなた、さっきの私の話——怒らないのね"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "怒る理由がない。正しいことを言ってた"
