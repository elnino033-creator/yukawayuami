  },
  {
    "text": {
      "name": "ひまり",
      "body": "すごい！ やった！ やったやったやった！"
    }
  },
  {
    "text": {
      "name": "",
      "body": "ひまりが叫びながら走ってくる。止まれないやつだ、と思った次の瞬間——"
    }
  },
  {
    "text": {
      "name": "",
      "body": "俺の腕にぶつかるように飛びついてきた。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "おっ——危ない。"
    }
  },
  {
    "text": {
      "name": "ひまり",
      "body": "やったじゃん！ 全部消えた！ ねえ見た！？"
    }
  },
  {
    "text": {
      "name": "ひまり",
      "body": "私も見てたよ！"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "わかった、離れろ。"
    }
  },
  {
    "text": {
      "name": "ひまり",
      "body": "やだ。……ちょっとだけ、こうさせて。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "さっきまでの騒がしさが嘘みたいに、ひまりの声が静かになった。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "俺の腕をぎゅっと抱えたまま、動かない。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "（……こいつは、急に静かになるから困る）"
    }
  },
  {
    "text": {
      "name": "ひまり",
      "body": "……ねえ。うれしいときに、こうしたくなるの。"
    }
  },
  {
    "text": {
      "name": "ひまり",
      "body": "変かな。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "変じゃない。"
    }
  },
  {
    "text": {
      "name": "ひまり",
      "body": "……よかった。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "ひまりはそのまま、しばらく俺の腕を抱えていた。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "歯車の回る音だけが、静かに響いていた。"
    }
  },
  {
    "chara": {
      "id": "himari",
      "hide": true
    }
  }
]
