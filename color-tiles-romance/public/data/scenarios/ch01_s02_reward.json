[
  {
    "bg": "stage1_bef"
  },
  {
    "bgm": "緋色のあかり"
  },
  {
    "chara": {
      "id": "akari",
      "expr": "smile",
      "pos": "center",
      "show": true
    }
  },
  {
    "text": {
      "name": "あかり",
      "body": "また完璧！ ほんとに、どうなってるの？ 私より全然うまいじゃん。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "お前が教えたんだろ。"
    }
  },
  {
    "text": {
      "name": "あかり",
      "body": "私が教えたのは最初だけだよ。今はもう関係ない。……あなた自身がすごいんだよ。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "あかりはそう言って、ふわっと俺の隣に並んだ。腕と腕が触れそうな距離。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "なんか、距離近くないか。"
    }
  },
  {
    "text": {
      "name": "あかり",
      "body": "……だめ？"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "だめとは言ってない。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "あかりはそれを聞いて、こっそり笑った。そして、ゆっくりと俺の腕に肩をもたせかけてくる。"
    }
  },
  {
    "text": {
      "name": "あかり",
      "body": "ちょっとだけ。……疲れた。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "（……本当に疲れてるのか、口実なのか、どっちだろう）"
    }
  },
  {
    "text": {
      "name": "",
      "body": "どちらでもよかった。あかりの肩の重さが、思いのほか心地よくて、俺はそのまま動かなかった。"
    }
  },
  {
    "text": {
      "name": "あかり",
      "body": "……ねえ。こういうの、いやじゃない？"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "いやじゃない。"
    }
  },
  {
    "text": {
      "name": "あかり",
      "body": "……よかった。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "あかりはそれきり何も言わなかった。ただ、もたれたまま、同じ場所をじっと見ていた。"
    }
  },
  {
    "chara": {
      "id": "akari",
      "hide": true
    }
  }
]
