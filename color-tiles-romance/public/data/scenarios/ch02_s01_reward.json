  {
    "text": {
      "name": "みお",
      "body": "……全部消えた。本当に、きれいに。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "みおはそう言って、少し間を置いた。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "俺の隣に、静かに並ぶ。"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "……あのさ。手、見せてもらえる？"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "手？"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "うん。……ちょっとだけ。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "みおは視線を伏せたまま、俺の手に指先をそっと当てた。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "確かめるように、薄く。まるで触れていないくらいの力で。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "（……こんなに静かに触れられたのは、初めてだ）"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "……あたたかいね。"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "そうか？"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "うん。……冷たい場所にいると、"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "こういうのが、じわって沁みる気がして。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "みおは指先を離さなかった。俺も動かなかった。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "なんとなく、邪魔したくなかった。"
    }
  },
  {
    "text": {
      "name": "みお",
      "body": "……変だった？"
    }
  },
  {
    "text": {
      "name": "主人公",
      "body": "変じゃない。"
    }
  },
  {
    "text": {
      "name": "",
      "body": "みおはそれを聞いて、ほんのわずか、指の力を強めた。"
    }
  },
  {
    "chara": {
      "id": "mio",
      "hide": true
    }
  }
